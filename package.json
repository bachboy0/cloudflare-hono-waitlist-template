{
  "name": "cloudflare-hono-waitlist-template",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "client": "bun run --bun astro dev",
    "build:client": "bun run --bun astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint 'src/**/*.{js,ts,tsx,astro}'",
    "worker": "wrangler dev",
    "dev": "concurrently \"bun run client\" \"bun run worker\"",
    "dryrun:staging": "bun run build:client && wrangler deploy --dry-run --env staging",
    "dryrun:prod": "bun run build:client && wrangler deploy --dry-run --env production",
    "deploy:staging": "bun run build:client && wrangler deploy --env staging",
    "deploy:prod": "bun run build:client && wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply dojo_local_db --local",
    "db:migrate:staging": "wrangler d1 migrations apply dojo_staging_db --remote --env staging"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.2.2",
    "concurrently": "^9.2.1",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "hono": "^4.12.17",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "wrangler": "^4.87.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260506.1",
    "@typescript-eslint/parser": "^8.59.2",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
